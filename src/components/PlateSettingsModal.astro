<div
  class="modal fade"
  id="plateSettingsModal"
  tabindex="-1"
  aria-labelledby="plateSettingsModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="plateSettingsModalLabel">
          Warm-up settings
        </h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-4 border rounded p-3">
          <h6 class="mb-2">Plate Presets</h6>
          <p class="text-muted small mb-3">
            Save bar weight and plate setup as named presets. Presets are
            stored only in this browser on this device.
          </p>

          <div class="mb-2">
            <label for="platePresetName" class="form-label"
              >New preset name</label
            >
            <div class="input-group">
              <input
                id="platePresetName"
                type="text"
                class="form-control"
                x-model="platePresetNameInput"
                @input="clearPresetStatus()"
                @keydown.enter.prevent="savePlatePreset()"
              />
              <button
                type="button"
                class="btn btn-outline-primary"
                @click="savePlatePreset()"
              >
                Save Preset
              </button>
            </div>
          </div>

          <div class="mb-2">
            <label class="form-label"
              >Saved presets (<span x-text="platePresets.length"
              ></span>)</label
            >
            <div
              class="list-group preset-list"
              x-show="platePresets.length > 0"
            >
              <template x-for="preset in platePresets" :key="preset.id">
                <button
                  type="button"
                  class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                  :class="preset.id === selectedPlatePresetId ? 'active' : ''"
                  @click="selectedPlatePresetId = preset.id; onPlatePresetSelectionChange()"
                >
                  <span x-text="preset.name"></span>
                  <span
                    class="badge text-bg-light"
                    x-show="preset.id === defaultPlatePresetId"
                    >Default</span
                  >
                </button>
              </template>
            </div>
          </div>

          <template x-if="platePresets.length === 0">
            <p class="text-muted small mb-2">
              No presets yet. Enter a name and save your current setup.
            </p>
          </template>

          <div class="mb-2" x-show="selectedPlatePresetId">
            <label for="platePresetRename" class="form-label"
              >Rename selected preset</label
            >
            <div class="input-group">
              <input
                id="platePresetRename"
                type="text"
                class="form-control"
                x-model="platePresetRenameInput"
                @input="clearPresetStatus()"
                @keydown.enter.prevent="renameSelectedPlatePreset()"
                @keydown.escape.prevent="onPlatePresetSelectionChange()"
              />
              <button
                type="button"
                class="btn btn-outline-secondary"
                @click="renameSelectedPlatePreset()"
              >
                Rename
              </button>
            </div>
          </div>

          <div
            class="d-flex flex-wrap gap-2 mb-2"
            x-show="platePresets.length > 0"
          >
            <button
              type="button"
              class="btn btn-outline-success btn-sm"
              :disabled="!selectedPlatePresetId"
              @click="applySelectedPlatePreset()"
            >
              Apply
            </button>
            <button
              type="button"
              class="btn btn-outline-danger btn-sm"
              :disabled="!selectedPlatePresetId"
              @click="deleteSelectedPlatePreset()"
            >
              Delete
            </button>
            <button
              type="button"
              class="btn btn-outline-dark btn-sm"
              :disabled="!selectedPlatePresetId"
              @click="setDefaultSelectedPlatePreset()"
            >
              Set Default
            </button>
            <button
              type="button"
              class="btn btn-outline-secondary btn-sm"
              :disabled="!defaultPlatePresetId"
              @click="clearDefaultPlatePreset()"
            >
              Clear Default
            </button>
          </div>

          <p class="small mb-1" x-show="defaultPlatePresetId">
            <span class="badge text-bg-secondary me-2">Default</span>
            <span
              x-text="platePresets.find((preset) => preset.id === defaultPlatePresetId)?.name || 'None'"
            ></span>
          </p>
          <div
            class="alert alert-danger py-2 mb-2"
            role="alert"
            aria-live="polite"
            x-show="platePresetError"
            x-text="platePresetError"
          >
          </div>
          <div
            class="alert alert-success py-2 mb-0"
            role="status"
            aria-live="polite"
            x-show="platePresetStatus"
            x-text="platePresetStatus"
          >
          </div>

          <div
            class="position-fixed bottom-0 end-0 p-3"
            style="z-index: 1080"
          >
            <div
              class="toast align-items-center border-0 show"
              :class="presetToastVariant === 'success' ? 'text-bg-success' : (presetToastVariant === 'warning' ? 'text-bg-warning' : 'text-bg-danger')"
              role="status"
              aria-live="polite"
              aria-atomic="true"
              x-show="showPresetToast"
              x-transition.opacity
            >
              <div class="d-flex">
                <div class="toast-body" x-text="presetToastMessage"></div>
                <button
                  type="button"
                  class="btn-close btn-close-white me-2 m-auto"
                  @click="showPresetToast = false"
                  aria-label="Close"></button>
              </div>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label for="barWeight" class="form-label"
            >Bar Weight (lbs)</label
          >
          <select
            class="form-select"
            id="barWeight"
            x-model.number="barWeight"
          >
            <template x-for="weight in barWeightOptions" :key="weight">
              <option
                :value="weight"
                :selected="Number(weight) === Number(barWeight)"
                x-text="weight"></option>
            </template>
          </select>
        </div>

        <div class="mb-3">
          <small class="text-muted"
            >Barbell warm-up sets are automatically optimized to reduce
            plate changes.</small
          >
        </div>

        <div class="mb-3">
          <div class="form-check form-switch">
            <input
              class="form-check-input"
              type="checkbox"
              id="enableBackoff"
              x-model="enableBackoff"
              @change="debouncedCalculate"
            />
            <label class="form-check-label" for="enableBackoff"
              >Show backoff sets</label
            >
          </div>
        </div>

        <div class="mb-3" x-show="enableBackoff">
          <label for="backoffPercentage" class="form-label"
            >Backoff Set Percentage</label
          >
          <div class="input-group">
            <input
              type="number"
              class="form-control"
              id="backoffPercentage"
              x-model.number="backoffPercentage"
              @input="debouncedCalculate"
              inputmode="decimal"
              step="0.1"
            />
            <span class="input-group-text">%</span>
          </div>
        </div>

        <h6 class="mb-3">Available Plates</h6>
        <div class="row row-cols-2 row-cols-md-3 g-2">
          <template
            x-for="(plate, index) in availablePlates"
            :key="plate.weight"
          >
            <div class="col">
              <div class="card p-2 h-100">
                <div class="form-check mb-2">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    :id="`plate-${plate.weight}`"
                    x-model="plate.available"
                  />
                  <label
                    class="form-check-label"
                    :for="`plate-${plate.weight}`"
                    x-text="`${plate.weight} lbs`"></label>
                </div>
                <label
                  class="form-label form-label-sm mb-1"
                  :for="`plate-count-${plate.weight}`">Count</label
                >
                <input
                  class="form-control form-control-sm"
                  type="number"
                  min="0"
                  step="1"
                  :id="`plate-count-${plate.weight}`"
                  :disabled="!plate.available"
                  x-model.number="plate.count"
                  @input="plate.count = Math.max(0, Math.floor(Number(plate.count) || 0))"
                />
              </div>
            </div>
          </template>
        </div>
      </div>
      <div class="modal-footer">
        <button
          type="button"
          class="btn btn-secondary"
          data-bs-dismiss="modal">Cancel</button
        >
        <button
          type="button"
          class="btn btn-primary"
          @click="savePlateSettings()"
          data-bs-dismiss="modal"
        >
          Save Settings
        </button>
      </div>
    </div>
  </div>
</div>
